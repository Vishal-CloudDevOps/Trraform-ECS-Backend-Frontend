[
  {
    "name": "demo-app-frontend",
    "image": "${image}",
    "essential": true,
    "portMappings": [
      { "containerPort": 80, "protocol": "tcp" }
    ],
    "environment": [
      { "name": "ENV_API_URL", "value": "${backend_url}" }
    ],
    "logConfiguration": {
      "logDriver": "awslogs",
      "options": {
        "awslogs-group": "/ecs/demo-frontend",
        "awslogs-region": "${region}",
        "awslogs-stream-prefix": "ecs"
      }
    }
  }
]